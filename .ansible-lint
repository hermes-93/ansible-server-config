---
profile: production

exclude_paths:
  - .git/
  - molecule/

skip_list:
  - yaml[line-length]            # handled by yamllint with a higher limit
  - var-naming[no-role-prefix]   # domain-prefixed vars (ssh_, fail2ban_) are intentional

warn_list:
  - experimental

loop_var_prefix: "^(item|{role}_)"

use_default_rules: true
